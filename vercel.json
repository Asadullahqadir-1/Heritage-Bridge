{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/admin/?",
      "dest": "/aadmin/index.html"
    },
    {
      "src": "/aadmin/?",
      "dest": "/aadmin/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
